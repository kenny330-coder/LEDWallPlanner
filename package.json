{
  "name": "LEDPowerPlanner",
  "private": true,
  "version": "1.0.7",
  "description": "LED wall configuration and power estimation utility",
  "author": "KennethChiara",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron": "concurrently -k \"vite\" \"wait-on tcp:5173 && electron .\"",
    "electron:build": "tsc -p electron/tsconfig.json && vite build && electron-builder",
    "electron:build:mac": "xattr -cr . && tsc -p electron/tsconfig.json && vite build && electron-builder --mac && mkdir -p release && cp /tmp/led-release/*.dmg release/ 2>/dev/null || true",
    "electron:build:win": "tsc -p electron/tsconfig.json && vite build && electron-builder --win --x64 && mkdir -p release && cp /tmp/led-release/*.exe release/ 2>/dev/null || true"
  },
  "build": {
    "appId": "com.ledplanner.app",
    "productName": "LED Power Planner",
    "afterPack": "build/afterPack.js",
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dmg",
      "icon": "build/icon.icns",
      "identity": "-",
      "artifactName": "${productName} v${version}.${ext}"
    },
    "dmg": {
      "title": "${productName} v${version}",
      "background": "node_modules/dmg-builder/templates/background.tiff",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 480
      }
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.png",
      "artifactName": "${productName} v${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "build/icon.png",
      "!**/*.{md,map,ts}",
      "!**/node_modules",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,LICENSE.md,LICENSE,assets/**,example/**,examples/**,test/**,tests/**,doc/**,docs/**}"
    ],
    "directories": {
      "output": "/tmp/led-release"
    },
    "asar": true,
    "extends": null
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "electron": "^40.4.1",
    "electron-builder": "^26.7.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jspdf": "^4.1.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.564.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.7.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "react-zoom-pan-pinch": "^3.7.0"
  }
}